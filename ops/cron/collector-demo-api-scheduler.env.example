# Non-secret scheduler configuration. Install as:
# /etc/azure-iac-msp-lab/collector-demo-api-scheduler.env
# owned by root:prs-scheduler and mode 0640.

GH_TOKEN_FILE=/etc/azure-iac-msp-lab/secrets/github-actions-dispatch.token
REPOSITORY=anthonyedgar30000/azure-iac-msp-lab
DEFAULT_BRANCH=main

# Exact reviewed commit. The scheduler fails closed when main differs.
# Replace this placeholder only after reviewing the commit to be planned.
REVIEWED_COMMIT=0000000000000000000000000000000000000000

RESOURCE_GROUP=rg-servicetracer-dev-westus2
LOCATION=westus2
LAB_ENVIRONMENT=dev
PREFIX=mst
DNS_LABEL=st-demo-api-aeg30000
ALLOWED_ORIGIN=https://anthonyedgar30000.github.io

# One initial attempt plus one read-only retry when the persistence controller
# specifically returns sync_with_reality for another what-if.
RETRY_BUDGET=1
POLL_INTERVAL_SECONDS=10
RUN_DISCOVERY_ATTEMPTS=30
RUN_COMPLETION_ATTEMPTS=540

STATE_ROOT=/var/lib/azure-iac-msp-lab/scheduler/collector-demo-api
RAW_EVIDENCE_ROOT=/var/lib/azure-iac-msp-lab/evidence/raw/collector-demo-api
SANITIZED_EVIDENCE_ROOT=/var/lib/azure-iac-msp-lab/evidence/sanitized/collector-demo-api
LOCK_FILE=/run/lock/collector-demo-api-scheduler.lock
